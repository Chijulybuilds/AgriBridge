# ─── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Supabase (off-chain DB + Auth) ────────────────────────
# Project settings → API. Anon key is used for user-scoped requests;
# the service-role key is SECRET and used only by trusted backend jobs.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ─── Auth (wallet sign-in / SIWE) ──────────────────────────
# Secret used to sign session JWTs after a wallet proves ownership.
# Generate a long random value, e.g.  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── Blockchain (on-chain protocol) ────────────────────────
# RPC endpoint for the target chain (e.g. Base Sepolia testnet).
RPC_URL=https://sepolia.base.org
CHAIN_ID=84532

# Backend "verifier" wallet — this key holds VERIFIER_ROLE / PRICE_UPDATER_ROLE.
# NEVER commit a real key. Use a testnet key funded from a faucet.
VERIFIER_PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY

# ─── Deployed contract addresses (from script/DeployAll.s.sol) ──
COMMODITY_REGISTRY_ADDRESS=0x...
COMMODITY_VERIFIER_ADDRESS=0x...
COMMODITY_TOKEN_ADDRESS=0x...
COMMODITY_PRICE_ORACLE_ADDRESS=0x...
LENDING_POOL_ADDRESS=0x...
LIQUIDITY_SHARE_TOKEN_ADDRESS=0x...
